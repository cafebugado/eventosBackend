# Supabase
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=changeme
SUPABASE_JWT_SECRET=changeme

# Banco de dados (conexao direta ao Postgres do Supabase)
DATABASE_URL=postgresql+asyncpg://postgres:senha@db.seu-projeto.supabase.co:5432/postgres

# Integracoes externas
GITHUB_TOKEN=ghp_changeme
GITHUB_REPO=cafebugado/agendas_eventos
GITHUB_REPO_BACKEND=cafebugado/backendEventos

# Observabilidade
SENTRY_DSN=

# OpenTelemetry (deixe em branco para desativar; ex.: endpoint OTLP HTTP do Grafana Cloud)
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=

# OAuth — URL para onde o Supabase redireciona apos login social
OAUTH_REDIRECT_URL=https://paineladmin.eventos.cafebugado.com.br/admin/auth/callback

# CORS
CORS_ORIGINS=http://localhost:5173,https://agendas-eventos.vercel.app

# Storage
SUPABASE_STORAGE_BUCKET=imagens
